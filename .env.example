# =============================================================
#  BioIntelligence Platform — Environment Variables Template
#  Copy this file to .env and fill in all required values.
#  Never commit .env to version control!
# =============================================================

# -------------------------------------------------------------
#  PostgreSQL
# -------------------------------------------------------------
# Strong password for the biointel database user.
POSTGRES_PASSWORD=changeme_strong_password

# -------------------------------------------------------------
#  Apache Airflow
# -------------------------------------------------------------
# Password for the Airflow web UI admin account.
AIRFLOW_ADMIN_PASSWORD=changeme_airflow

# Fernet key used to encrypt sensitive connection credentials
# stored in the Airflow metadata database.
# Generate a new key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=

# -------------------------------------------------------------
#  Apache Superset
# -------------------------------------------------------------
# Secret key used to sign session cookies — must be long and random.
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SUPERSET_SECRET_KEY=changeme_superset_secret

# Password for the Superset web UI admin account.
SUPERSET_ADMIN_PASSWORD=changeme_superset

# -------------------------------------------------------------
#  HuggingFace Hub
# -------------------------------------------------------------
# No token is required for public models, but setting
# HUGGINGFACE_HUB_TOKEN speeds up downloads and avoids
# rate-limiting.  Leave blank if you don't have one.
# HUGGINGFACE_HUB_TOKEN=hf_your_token_here

# Local cache directory for model weights (inside container).
# Mapped to the host ./models directory via the model-weights volume.
HUGGINGFACE_HUB_CACHE=/opt/biointel/models

# -------------------------------------------------------------
#  Device Configuration
# -------------------------------------------------------------
# Set to "cuda" if a GPU is available, otherwise keep "cpu".
# The Airflow worker will pass this to all ML inference scripts.
MODEL_DEVICE=cpu

# -------------------------------------------------------------
#  Data Paths (inside containers)
# -------------------------------------------------------------
# These are the container-side mount points for the bind volumes
# defined in docker-compose.yml.  Change only if you remap them.
RAW_DATA_DIR=/opt/biointel/data
MODEL_WEIGHTS_DIR=/opt/biointel/models
